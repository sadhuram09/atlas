*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
.venv/
venv/
env/
.python-version

# --- Testing ---
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# --- Docker ---
*.log

# --- Node (for frontend in Phase 4) ---
node_modules/
.next/
dist/
.vercel/

# --- Database ---
*.sqlite3
*.db

# --- Runtime / generated data ---
atlas_memory/
*.zip

.vercel
