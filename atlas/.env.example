# ============================================================
# ATLAS Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env — it's in .gitignore.
#
# Railway: set these in your project → Variables tab.
# Local:   cp .env.example .env  then edit the values below.
# ============================================================

# ------ App ------
APP_NAME=ATLAS
APP_VERSION=0.1.0
ENVIRONMENT=development          # development | staging | production
DEBUG=true
LOG_LEVEL=INFO

# ------ Server ------
HOST=0.0.0.0
PORT=8000

# ------ LLM API Keys ------
# Groq — free, no credit card needed
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ------ Models (Groq free tier) ------
# FAST:     llama-3.1-8b-instant        (quickest, drafts + simple tasks)
# BALANCED: llama-3.3-70b-versatile     (best all-rounder — use this most)
# POWERFUL: deepseek-r1-distill-llama-70b (reasoning + hard tasks)
MODEL_FAST=llama-3.1-8b-instant
MODEL_BALANCED=llama-3.3-70b-versatile
MODEL_POWERFUL=deepseek-r1-distill-llama-70b

# ------ Database (Phase 2+) ------
# Local: uses Docker Compose postgres service
DATABASE_URL=postgresql+asyncpg://atlas:atlas@localhost:5432/atlas

# ------ LangSmith (Phase 2+) ------
# Get from: https://smith.langchain.com/
LANGSMITH_API_KEY=ls-your-key-here
LANGSMITH_PROJECT=atlas-designpro
LANGCHAIN_TRACING_V2=false

# ------ CORS ------
# Comma-separated origins allowed to call the API
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","https://designpro.app"]
